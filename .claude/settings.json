{
  "agent": "architect",
  "model": "opus",
  "permissions": {
    "allow": [
      "Bash(*)",
      "Read",
      "Glob",
      "Grep",
      "Write",
      "Edit",
      "WebFetch",
      "WebSearch",
      "Agent",
      "Skill"
    ],
    "deny": [
      "Bash(git push --force *)",
      "Bash(rm -rf /)"
    ]
  },
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/stop-metrics.sh"
          }
        ]
      }
    ]
  }
}
